# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your keys. The app reads from `.env`.
# Every key is OPTIONAL: with a key missing, that stage degrades gracefully
# (heuristics still run) instead of crashing.
# ──────────────────────────────────────────────────────────────────────────

# DeepSeek (LLM "brain"). OpenAI-compatible API.
# Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# deepseek-chat is valid until 2026-07-24; deepseek-v4-flash is the successor.
DEEPSEEK_MODEL=deepseek-chat

# Apify (LinkedIn job search + company lookup).
# Get a token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=
# Actor that scrapes LinkedIn jobs (override if you prefer a different one).
APIFY_LINKEDIN_JOBS_ACTOR=bebity~linkedin-jobs-scraper

# Tavily (web-search fallback for discovery + website lookup).
# Get a key at https://app.tavily.com/  (1,000 free credits/month, no card)
TAVILY_API_KEY=

# ── Tuning ───────────────────────────────────────────────────────────────
# How many top candidates get the full resolution pipeline (the rest stay shallow).
DEEP_RESOLVE_TOP_N=3
# Per-page browser timeout (ms).
BROWSER_TIMEOUT_MS=20000
# Run the browser with a visible window (1) or headless (0).
BROWSER_HEADLESS=1
